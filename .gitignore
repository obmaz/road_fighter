### Android ###
# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/

# Local configuration file (for local passwords, etc)
local.properties

# Proguard folder generated by Gradle
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio capturing tool
*.capt

# IntelliJ project files
*.iml
.idea/modules.xml
.idea/workspace.xml
.idea/tasks.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches

# Keystore files
*.jks
*.keystore

# External native build flags
.externalNativeBuild

# Google Services file
google-services.json

# Freeline
freeline.py
freeline/
freeline-project.json

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output

# Bundletool
*.apks

### Dart ###
.dart_tool/

# pubspec.lock is usually not checked in for applications
pubspec.lock

